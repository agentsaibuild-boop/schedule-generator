#!/bin/bash
# Pre-commit hook: Run unit tests before allowing commit
# E2E tests are slow and environment-dependent — run manually with: pytest tests/e2e/ -v -m e2e
# Install with: ./install-hooks.bat (Windows) or cp hooks/pre-commit .git/hooks/pre-commit

set -e

echo "============================================"
echo "  Pre-commit: Running unit tests..."
echo "============================================"

# Change to repo root
cd "$(git rev-parse --show-toplevel)"

# --- Run unit/integration tests ---
echo ""
echo "[1/1] Running unit tests (test_exports.py)..."
python -m pytest tests/test_exports.py -v --tb=short --no-header -q
if [ $? -ne 0 ]; then
    echo ""
    echo "UNIT TESTS FAILED. Commit aborted."
    exit 1
fi

echo ""
echo "============================================"
echo "  Unit tests passed! Proceeding with commit."
echo "  (Run E2E tests manually: pytest tests/e2e/ -v -m e2e)"
echo "============================================"
